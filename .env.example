# LLM — 火山引擎方舟 (Doubao)
LLM_BACKEND=doubao
ARK_API_KEY=your-volcengine-ark-api-key
LLM_ENDPOINT_ID=ep-20250101xxxxxx-xxxxx

# STT — faster-whisper
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
HF_HOME=D:\AI\models\huggingface
HF_ENDPOINT=https://hf-mirror.com

# TTS — 火山引擎 (volc) 或 edge-tts (edge)
TTS_BACKEND=volc
TTS_VOICE=BV001_streaming
VOLC_APP_ID=your-volc-app-id
VOLC_ACCESS_TOKEN=your-volc-access-token

# Recording
SAMPLE_RATE=16000
RECORD_SECONDS=5
